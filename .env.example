# ─────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────

# MongoDB connection string
# Docker default: mongodb://localhost:27017/osher
# Atlas example: mongodb+srv://<user>:<pass>@cluster.mongodb.net/osher
MONGO_URI=mongodb://localhost:27017/osher

# JWT signing secret — use a long random string (32+ chars)
JWT_SECRET=replace_this_with_a_long_random_secret

# ─────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────

# Backend port (default: 3000)
PORT=3000

# Environment
NODE_ENV=development
